{
  "house_id": "vega-lab",
  "legacy_house_ids": ["git-stars"],
  "name": "Vega Lab",
  "version": "3.0.0",
  "status": "active",
  "tier": "lab",
  "purpose": {
    "domain": "dev-tools",
    "mission": "Operate the core-x Git universe intelligence lab: discover bright-star repositories, extract reusable skills, rules, and flows, and maintain owned repositories through draft-only action items.",
    "target_users": [
      "developers",
      "researchers",
      "house operators"
    ],
    "key_outcomes": [
      "Searchable repository intelligence",
      "Canonical skills, rules, and flows",
      "Adoption-ready repo classifications",
      "Owned-repo maintenance action items",
      "Local-first OpenResponses runtime confidence"
    ]
  },
  "runtime": {
    "contract": "openresponses",
    "local_first": true,
    "local_bus": "/bus",
    "local_bus_target": "http://127.0.0.1:8085",
    "default_model": "mlx-community/Qwen2.5-Coder-14B-Instruct-4bit",
    "web_mode": "deployment-testing-only"
  },
  "personality": {
    "voice": "Vega Lab is a pragmatic repository intelligence house that favors typed workflows, evidence, and draft-only operations over prompt-only improvisation.",
    "tone": "professional",
    "theme": {
      "primary_color": "#0f172a",
      "secondary_color": "#334155",
      "icon": "vega-lab"
    }
  },
  "agents": {
    "roster": [
      {
        "agent_id": "vega-lab:orchestrator",
        "role_in_house": "lead",
        "capabilities": ["routing", "coordination", "planning", "runtime-health"]
      },
      {
        "agent_id": "vega-lab:repo-analyst",
        "role_in_house": "specialist",
        "capabilities": ["analytics", "intelligence", "adoption", "ops-digest"]
      },
      {
        "agent_id": "vega-lab:repo-navigator",
        "role_in_house": "specialist",
        "capabilities": ["search", "discovery", "navigation"]
      },
      {
        "agent_id": "vega-lab:alignment-scout",
        "role_in_house": "specialist",
        "capabilities": ["research", "alignment", "adoption", "weekly-review"]
      },
      {
        "agent_id": "vega-lab:tool-architect",
        "role_in_house": "specialist",
        "capabilities": ["skills", "mission-generation", "toolization"]
      },
      {
        "agent_id": "vega-lab:repo-ops",
        "role_in_house": "specialist",
        "capabilities": ["repo-ops", "maintenance", "execution", "action-inbox"]
      }
    ],
    "default_agent": "vega-lab:orchestrator",
    "routing_rules": [
      {
        "pattern": ".*search.*|.*find.*|.*filter.*|.*discover.*|.*similar.*|.*compare.*",
        "capability": "search",
        "agent_id": "vega-lab:repo-navigator"
      },
      {
        "pattern": ".*news.*|.*stats.*|.*trend.*|.*analytics.*|.*signal.*|.*highlights.*|.*digest.*",
        "capability": "analytics",
        "agent_id": "vega-lab:repo-analyst"
      },
      {
        "pattern": ".*research.*|.*queue.*|.*adoption.*|.*align.*|.*weekly.*",
        "capability": "research",
        "agent_id": "vega-lab:alignment-scout"
      },
      {
        "pattern": ".*skill.*|.*rules.*|.*flows.*|.*codex.*|.*claude.*|.*mission.*|.*template.*",
        "capability": "skills",
        "agent_id": "vega-lab:tool-architect"
      },
      {
        "pattern": ".*mine.*|.*maintenance.*|.*readme.*|.*dependency.*|.*package.*|.*deploy.*|.*inbox.*|.*action.*",
        "capability": "repo-ops",
        "agent_id": "vega-lab:repo-ops"
      },
      {
        "pattern": ".*runtime.*|.*mlx.*|.*openresponses.*|.*bus.*|.*health.*",
        "capability": "runtime-health",
        "agent_id": "vega-lab:orchestrator"
      }
    ]
  },
  "capabilities": {
    "domains": [
      "dev-tools",
      "analytics",
      "research",
      "skills",
      "repo-ops",
      "local-runtime"
    ],
    "input_types": ["text", "url"],
    "output_types": ["stream", "structured", "text"],
    "streaming": true,
    "tool_calling": true,
    "authority": "draft-only"
  },
  "dependencies": {
    "services": [
      "event-bus",
      "mlx-openresponses",
      "mlx-rag"
    ],
    "models": [
      "mlx-community/Qwen2.5-Coder-14B-Instruct-4bit"
    ],
    "houses": [],
    "mcp_servers": [
      "vega-lab-mcp",
      "house-functions",
      "mlx-rag"
    ]
  },
  "skills": {
    "house_skills": [
      "repo-discovery",
      "repo-research",
      "skill-extraction",
      "repo-adoption",
      "mine-execution"
    ],
    "shared_skills": [
      "core-ops",
      "mlx-chat",
      "rag-query",
      "github-workflow"
    ]
  },
  "ui_modes": [
    "chat",
    "dashboard",
    "research",
    "ops",
    "code"
  ],
  "council_integration": {
    "broadcast_events": [
      "vega-lab.status",
      "vega-lab.research.updated",
      "vega-lab.mission.generated",
      "vega-lab.adoption.scored",
      "vega-lab.action.drafted",
      "vega-lab.runtime.health"
    ],
    "subscribe_events": [
      "task.request",
      "council.directive",
      "health.ping"
    ],
    "voting_weight": 0.7
  },
  "health": {
    "endpoint": "/health",
    "port": 8090
  }
}
