  "workflows": {
    "flows": [
      {
        "id": "news-digest-refresh",
        "name": "News Digest Refresh",
        "description": "Refresh hybrid News signals, then summarize the most relevant updates, evidence, and adoption moves.",
        "trigger": {
          "event": "task.news",
          "pattern": ".*news.*|.*highlight.*|.*signal.*|.*trend.*"
        },
        "steps": [
          { "step_id": "signals", "agent_id": "vega-lab:repo-analyst", "action": "list_news_signals", "output_to": "summary" },
          { "step_id": "digest", "agent_id": "vega-lab:repo-analyst", "action": "generate_ops_digest", "input_from": "signals", "output_to": "summary" }
        ]
      },
      {
        "id": "research-queue-flow",
        "name": "Research Queue Flow",
        "description": "Queue a repo, extract fit, and produce a short research brief.",
        "trigger": {
          "event": "task.research",
          "pattern": ".*research.*|.*queue.*|.*align.*"
        },
        "steps": [
          { "step_id": "queue", "agent_id": "vega-lab:alignment-scout", "action": "update_research_queue", "output_to": "extract" },
          { "step_id": "extract", "agent_id": "vega-lab:alignment-scout", "action": "extract_repo_skills", "input_from": "queue", "output_to": "brief" },
          { "step_id": "action", "agent_id": "vega-lab:repo-ops", "action": "draft_action_item", "input_from": "brief" }
        ]
      },
      {
        "id": "skill-extraction-flow",
        "name": "Skill Extraction Flow",
        "description": "Extract canonical skills, rules, flows, and optional model-specific missions.",
        "trigger": {
          "event": "task.skills",
          "pattern": ".*skill.*|.*rules.*|.*flows.*|.*codex.*|.*claude.*|.*mission.*"
        },
        "steps": [
          { "step_id": "extract", "agent_id": "vega-lab:tool-architect", "action": "extract_repo_skills", "output_to": "mission" },
          { "step_id": "mission", "agent_id": "vega-lab:tool-architect", "action": "generate_repo_mission", "input_from": "extract" }
        ]
      },
      {
        "id": "adoption-decision-flow",
        "name": "Adoption Decision Flow",
        "description": "Evaluate adoption fit and convert it into a category and next action.",
        "trigger": {
          "event": "task.adoption",
          "pattern": ".*adopt.*|.*fit.*|.*integrate.*|.*house.*|.*tool.*|.*template.*"
        },
        "steps": [
          { "step_id": "extract", "agent_id": "vega-lab:alignment-scout", "action": "extract_repo_skills", "output_to": "rank" },
          { "step_id": "rank", "agent_id": "vega-lab:repo-analyst", "action": "get_adoption_candidates", "input_from": "extract", "output_to": "decision" },
          { "step_id": "action", "agent_id": "vega-lab:repo-ops", "action": "draft_action_item", "input_from": "decision" }
        ]
      },
      {
        "id": "mine-execution-flow",
        "name": "Mine Execution Flow",
        "description": "Inspect owned-repo health, identify readiness gaps, and draft execution actions.",
        "trigger": {
          "event": "task.mine",
          "pattern": ".*mine.*|.*maintenance.*|.*readme.*|.*dependency.*|.*package.*|.*deploy.*"
        },
        "steps": [
          { "step_id": "health", "agent_id": "vega-lab:repo-ops", "action": "get_mine_health", "output_to": "inspection" },
          { "step_id": "inspection", "agent_id": "vega-lab:repo-ops", "action": "inspect_owned_repo", "input_from": "health", "output_to": "actions" },
          { "step_id": "actions", "agent_id": "vega-lab:repo-ops", "action": "list_action_items", "input_from": "inspection" }
        ]
      },
      {
        "id": "daily-ops-automation",
        "name": "Daily Ops Automation",
        "description": "Refresh snapshots, inspect owned repos, generate an ops digest, and draft action inbox items. This flow is draft-only.",
        "trigger": {
          "event": "automation.daily-ops",
          "pattern": ".*daily.*ops.*"
        },
        "authority": "draft-only",
        "steps": [
          { "step_id": "health", "agent_id": "vega-lab:orchestrator", "action": "get_runtime_health", "output_to": "inspection" },
          { "step_id": "inspection", "agent_id": "vega-lab:repo-ops", "action": "get_mine_health", "output_to": "digest" },
          { "step_id": "digest", "agent_id": "vega-lab:repo-analyst", "action": "generate_ops_digest", "input_from": "inspection", "output_to": "inbox" },
          { "step_id": "inbox", "agent_id": "vega-lab:repo-ops", "action": "list_action_items", "input_from": "digest" }
        ]
      },
      {
        "id": "weekly-research-automation",
        "name": "Weekly Research Automation",
        "description": "Rank bright-star candidates, update research recommendations, identify reusable skills, rules, and flows, and generate the weekly review. This flow is draft-only.",
        "trigger": {
          "event": "automation.weekly-research",
          "pattern": ".*weekly.*research.*"
        },
        "authority": "draft-only",
        "steps": [
          { "step_id": "candidates", "agent_id": "vega-lab:repo-analyst", "action": "get_adoption_candidates", "output_to": "review" },
          { "step_id": "review", "agent_id": "vega-lab:alignment-scout", "action": "generate_weekly_research_review", "input_from": "candidates", "output_to": "actions" },
          { "step_id": "actions", "agent_id": "vega-lab:repo-ops", "action": "list_action_items", "input_from": "review" }
        ]
      }
