  "workflows": {
    "flows": [
      {
        "id": "news-digest-refresh",
        "name": "News Digest Refresh",
        "description": "Refresh hybrid News signals, then summarize the most relevant updates and adoption moves.",
        "trigger": {
          "event": "task.news",
          "pattern": ".*news.*|.*highlight.*|.*signal.*|.*trend.*"
        },
        "steps": [
          { "step_id": "signals", "agent_id": "git-stars:repo-analyst", "action": "list_news_signals", "output_to": "summary" },
          { "step_id": "summary", "agent_id": "git-stars:repo-analyst", "action": "summarize_news_signals", "input_from": "signals" }
        ]
      },
      {
        "id": "research-queue-flow",
        "name": "Research Queue Flow",
        "description": "Queue a repo, extract fit, and produce a short research brief.",
        "trigger": {
          "event": "task.research",
          "pattern": ".*research.*|.*queue.*|.*align.*"
        },
        "steps": [
          { "step_id": "queue", "agent_id": "git-stars:alignment-scout", "action": "update_research_queue", "output_to": "extract" },
          { "step_id": "extract", "agent_id": "git-stars:alignment-scout", "action": "extract_repo_skills", "input_from": "queue", "output_to": "brief" },
          { "step_id": "brief", "agent_id": "git-stars:alignment-scout", "action": "write_research_brief", "input_from": "extract" }
        ]
      },
      {
        "id": "skill-extraction-flow",
        "name": "Skill Extraction Flow",
        "description": "Extract canonical skills, rules, flows, and optional model-specific missions.",
        "trigger": {
          "event": "task.skills",
          "pattern": ".*skill.*|.*rules.*|.*flows.*|.*codex.*|.*claude.*|.*mission.*"
        },
        "steps": [
          { "step_id": "extract", "agent_id": "git-stars:tool-architect", "action": "extract_repo_skills", "output_to": "mission" },
          { "step_id": "mission", "agent_id": "git-stars:tool-architect", "action": "generate_repo_mission", "input_from": "extract" }
        ]
      },
      {
        "id": "adoption-decision-flow",
        "name": "Adoption Decision Flow",
        "description": "Evaluate adoption fit and convert it into a category and next action.",
        "trigger": {
          "event": "task.adoption",
          "pattern": ".*adopt.*|.*fit.*|.*integrate.*|.*house.*|.*tool.*|.*template.*"
        },
        "steps": [
          { "step_id": "extract", "agent_id": "git-stars:alignment-scout", "action": "extract_repo_skills", "output_to": "rank" },
          { "step_id": "rank", "agent_id": "git-stars:repo-analyst", "action": "get_adoption_candidates", "input_from": "extract", "output_to": "decision" },
          { "step_id": "decision", "agent_id": "git-stars:alignment-scout", "action": "write_adoption_decision", "input_from": "rank" }
        ]
      },
      {
        "id": "mine-execution-flow",
        "name": "Mine Execution Flow",
        "description": "Load owned-repo health, identify readiness gaps, and produce execution actions.",
        "trigger": {
          "event": "task.mine",
          "pattern": ".*mine.*|.*maintenance.*|.*readme.*|.*dependency.*|.*package.*"
        },
        "steps": [
          { "step_id": "health", "agent_id": "git-stars:repo-ops", "action": "get_mine_health", "output_to": "mission" },
          { "step_id": "mission", "agent_id": "git-stars:repo-ops", "action": "generate_repo_mission", "input_from": "health", "output_to": "actions" },
          { "step_id": "actions", "agent_id": "git-stars:repo-ops", "action": "write_execution_actions", "input_from": "mission" }
        ]
      }
    ]
